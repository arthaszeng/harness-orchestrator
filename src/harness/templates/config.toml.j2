[project]
name = "{{ project_name }}"
description = "{{ description }}"
lang = "{{ lang }}"

[ci]
command = "{{ ci_command }}"
architecture_check = ""
frontend_dir = ""

[models]
default = ""

[workflow]
max_iterations = 3
pass_threshold = 7.0
auto_merge = true
branch_prefix = "agent"
trunk_branch = "{{ trunk_branch }}"
task_id_strategy = "hybrid"
task_id_custom_pattern = ""
# Estimated token budget for task artifacts (chars/4 approximation)
# context_budget_tokens = 50000

# Progressive trust thresholds (review gate adjustment advisory)
# [workflow.trust]
# accuracy_high = 0.85
# accuracy_medium = 0.70
# min_samples_high = 10
# min_samples_medium = 5
# probation_revert_window = 3

[native]
evaluator_model = "{{ evaluator_model }}"
adversarial_mechanism = "auto"
review_gate = "eng"
gate_full_review_min = {{ gate_full_review_min }}
gate_summary_confirm_min = {{ gate_summary_confirm_min }}

[integrations.memverse]
enabled = {{ memverse_enabled | lower }}
domain_prefix = "{{ memverse_domain }}"
