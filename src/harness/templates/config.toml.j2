[project]
name = "{{ project_name }}"
description = "{{ description }}"
lang = "{{ lang }}"

[ci]
command = "{{ ci_command }}"
architecture_check = ""
frontend_dir = ""

[models]
default = ""

[workflow]
max_iterations = 3
pass_threshold = 7.0
auto_merge = true
branch_prefix = "agent"
trunk_branch = "{{ trunk_branch }}"

[native]
adversarial_model = "{{ adversarial_model }}"
adversarial_mechanism = "auto"
review_gate = "eng"
gate_full_review_min = {{ gate_full_review_min }}
gate_summary_confirm_min = {{ gate_summary_confirm_min }}

[integrations.memverse]
enabled = {{ memverse_enabled | lower }}
domain_prefix = "{{ memverse_domain }}"
